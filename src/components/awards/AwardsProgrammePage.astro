---
import type { AwardsCategory, AwardsProgramme } from "../../data/awards";
import AwardsCategoryCards from "./AwardsCategoryCards.astro";
import AwardsHero from "./AwardsHero.astro";
import AwardsLinkGrid from "./AwardsLinkGrid.astro";
import AwardsSectionBlocks from "./AwardsSectionBlocks.astro";
import AwardsSponsorGrid from "./AwardsSponsorGrid.astro";

type Props = {
  programme: AwardsProgramme;
  categories: AwardsCategory[];
};

const { programme, categories } = Astro.props;
---

<AwardsHero
  eyebrow={programme.heroEyebrow}
  title={programme.title}
  summary={programme.summary}
  heroLabel={programme.heroLabel}
  statusText={programme.statusText}
  heroImageUrl={programme.heroImageUrl}
  timeline={programme.timeline}
  highlights={programme.highlights}
  ctaLinks={programme.ctaLinks}
/>

<section class="section section-tight">
  <div class="detail-grid awards-intro-grid">
    <article class="card info-card awards-story-card">
      <p class="eyebrow">Programme overview</p>
      <h2>{programme.yearLabel} in one place</h2>
      <div class="stack">
        {programme.intro.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </article>

    <article class="card info-card awards-stats-card">
      <p class="eyebrow">Key details</p>
      <h2>What to know before you plan or enter</h2>
      <dl class="awards-stat-grid">
        {programme.stats.map((stat) => (
          <div class="awards-stat-item">
            <dt>{stat.label}</dt>
            <dd>{stat.value}</dd>
          </div>
        ))}
      </dl>
      <div class="awards-programme-facts">
        {programme.eventDateText && <span>{programme.eventDateText}</span>}
        {programme.venueName && <span>{programme.venueName}</span>}
        {programme.venueCity && <span>{programme.venueCity}</span>}
      </div>
    </article>
  </div>
</section>

<AwardsCategoryCards
  categories={categories}
  title={programme.categoryIntroTitle ?? "Award categories"}
  summary={programme.categoryIntroSummary}
/>

<section class="section section-tight">
  <div class="detail-grid awards-content-grid">
    <AwardsLinkGrid title="Planning and supporting pages" links={programme.mediaLinks} />
    <AwardsSectionBlocks sections={programme.sections} />
  </div>
</section>

<AwardsSponsorGrid title={programme.sponsorsTitle} summary={programme.sponsorsSummary} sponsors={programme.sponsors} />
