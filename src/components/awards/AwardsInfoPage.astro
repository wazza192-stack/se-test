---
import type { AwardsCategory, AwardsPage } from "../../data/awards";
import AwardsCategoryCards from "./AwardsCategoryCards.astro";
import AwardsHero from "./AwardsHero.astro";
import AwardsLinkGrid from "./AwardsLinkGrid.astro";
import AwardsSectionBlocks from "./AwardsSectionBlocks.astro";
import AwardsSponsorGrid from "./AwardsSponsorGrid.astro";

type Props = {
  page: AwardsPage;
  categories?: AwardsCategory[];
};

const { page, categories = [] } = Astro.props;
const showCategories = page.slug === "award-categories" && categories.length > 0;
---

<AwardsHero
  eyebrow={page.heroEyebrow}
  title={page.title}
  summary={page.summary}
  heroLabel={page.heroLabel}
  statusText={page.statusText}
  heroImageUrl={page.heroImageUrl}
  timeline={page.timeline}
  highlights={page.highlights}
  ctaLinks={page.ctaLinks}
/>

<section class="section section-tight">
  <div class="detail-grid awards-intro-grid">
    <article class="card info-card awards-story-card">
      <p class="eyebrow">Page overview</p>
      <h2>Structured for regular updates</h2>
      <div class="stack">
        {page.intro.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </article>

    <article class="card info-card awards-stats-card">
      <p class="eyebrow">At a glance</p>
      <h2>Key information for this page</h2>
      <dl class="awards-stat-grid">
        {page.stats.map((stat) => (
          <div class="awards-stat-item">
            <dt>{stat.label}</dt>
            <dd>{stat.value}</dd>
          </div>
        ))}
      </dl>
    </article>
  </div>
</section>

{showCategories && (
  <AwardsCategoryCards
    categories={categories}
    title="Current live categories"
    summary="Categories are connected to the current awards year and can be edited individually without changing this page template."
  />
)}

<section class="section section-tight">
  <div class="detail-grid awards-content-grid">
    <AwardsLinkGrid title="Related awards pages" links={page.mediaLinks} />
    <AwardsSectionBlocks sections={page.sections} />
  </div>
</section>

<AwardsSponsorGrid title={page.sponsorsTitle} summary={page.sponsorsSummary} sponsors={page.sponsors} />
