---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getJobListings } from "../../lib/content";

const jobListings = await getJobListings();

const getClubInitials = (value: string) =>
  value
    .split(/[\s&(]+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((part) => part[0]?.toUpperCase() ?? "")
    .join("");
---

<BaseLayout
  title="Stadium Jobs"
  description="Careers and recruitment opportunities across stadium conference, events and hospitality teams."
>
  <section class="page-hero">
    <p class="eyebrow">Stadium Jobs</p>
    <h1>Careers across the stadium events industry</h1>
    <p class="lede">
      Explore roles in sales, hospitality and operations from venues across the Stadium
      Experience network.
    </p>
  </section>

  <section class="section section-tight">
    <div class="stadium-jobs-grid">
      {jobListings.map((job) => (
        <article class="card stadium-job-listing-card">
          <div class="stadium-job-listing-badge">
            {job.crestUrl ? (
              <img src={job.crestUrl} alt="" loading="lazy" class="stadium-job-listing-crest" />
            ) : (
              <div class="club-hero-fallback club-hero-fallback-clean" aria-hidden="true">
                {getClubInitials(job.location)}
              </div>
            )}
          </div>
          <h2>
            <a class="stadium-job-listing-title-link" href={`/stadium-jobs/${job.slug}/`}>
              {job.title} at {job.location}
            </a>
          </h2>
          {job.closingDate ? (
            <p class="stadium-job-listing-date">Closing Date: <strong>{job.closingDate}</strong></p>
          ) : (
            <p class="stadium-job-listing-date">Role type: <strong>{job.type}</strong></p>
          )}
          <div class="stadium-job-listing-actions">
            <a class="button button-primary stadium-job-listing-button" href={`/stadium-jobs/${job.slug}/`}>
              Click here
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
