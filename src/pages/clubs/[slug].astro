---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getClubPageBySlug } from "../../lib/club-pages";

const { slug } = Astro.params;
let clubPage;

try {
  clubPage = slug ? await getClubPageBySlug(slug) : undefined;
} catch (error) {
  console.error("Unable to load club page", error);
}

if (!clubPage) {
  Astro.response.status = 404;
}

const club = clubPage?.club;
const clubInitials = club
  ? club.name
      .split(/[\s&(]+/)
      .filter(Boolean)
      .slice(0, 2)
      .map((part) => part[0]?.toUpperCase() ?? "")
      .join("")
  : "";
const heroImage = clubPage?.heroImageUrl ?? null;
const clubName = clubPage?.clubName ?? club?.name ?? "this venue";
const heroLead =
  clubPage?.summary ??
  (club ? `Explore venue information, event opportunities and public contact details for ${club.name}.` : "");
const fallbackSeoTitle = club ? `${club.name} | Stadium Experience` : "Club not found | Stadium Experience";
const fallbackSeoDescription =
  clubPage?.summary ??
  (club
    ? `Explore venue information, key facts, event spaces and enquiry details for ${club.name}.`
    : "The requested club page could not be found.");
const canonicalPath = club ? `/clubs/${club.slug}/` : null;
const overviewHeading = clubPage?.introductionHeading ?? `Why planners choose ${clubName}`;
const sectionAnchorFor = (sectionKey: string, index: number) =>
  sectionKey === "custom" ? `section-custom-${index + 1}` : `section-${sectionKey}`;
const contentSections = clubPage?.contentSections.filter((section) => section.items.length) ?? [];
const experiencesAnchor = "section-experiences";
const mapAnchor = "section-map";
const uniqueImageList = (items: Array<string | null | undefined>) =>
  items.filter((item, index, array): item is string => Boolean(item) && array.indexOf(item) === index);
const spacesGallery = uniqueImageList([clubPage?.heroImageUrl, clubPage?.playOnPitchImageUrl, clubPage?.christmasImageUrl]);
const eventsGallery = uniqueImageList([clubPage?.playOnPitchImageUrl, clubPage?.christmasImageUrl, clubPage?.heroImageUrl]);
const mapNarrative = [
  clubPage?.summary,
  ...(clubPage?.introduction.slice(0, 2) ?? [])
].filter((paragraph, index, array): paragraph is string => Boolean(paragraph) && array.indexOf(paragraph) === index);
const sectionLinks = [
  clubPage?.keyFacts.length ? { href: "#key-information", label: "Key Information" } : null,
  ...contentSections.map((section, index) => ({
    href: `#${sectionAnchorFor(section.sectionKey, index)}`,
    label: section.heading
  })),
  clubPage?.specialExperiences.length ? { href: `#${experiencesAnchor}`, label: "Experiences" } : null,
  clubPage?.mapEmbedUrl ? { href: `#${mapAnchor}`, label: "Map" } : null
].filter(Boolean);
---

<BaseLayout
  seo={clubPage?.seo}
  title={fallbackSeoTitle}
  description={fallbackSeoDescription}
  canonicalPath={canonicalPath}
  socialImage={heroImage}
  noindex={!clubPage}
>
  {clubPage ? (
    <div class="club-page-shell">
      <section class="club-hero section">
        <div
          class:list={["club-hero-stage", !heroImage && "club-hero-stage-fallback"]}
          style={heroImage ? `--club-hero-image:url('${heroImage}')` : undefined}
        >
          <div class="club-hero-overlay"></div>
          <div class="club-hero-card">
            <div class="club-hero-badge">
              {club.crestUrl ? (
                <img src={club.crestUrl} alt="" loading="eager" class="club-hero-image-clean" />
              ) : (
                <div class="club-hero-fallback club-hero-fallback-clean" aria-hidden="true">{clubInitials}</div>
              )}
            </div>
            <div class="club-hero-copy-clean">
              <p class="eyebrow">{clubPage.heroEyebrow ?? "Club profile"}</p>
              <h1>{club.name}</h1>
              <p class="club-hero-venue-clean">{clubName}</p>
              <p class="lede">{heroLead}</p>
              {clubPage.heroCaption && <p class="club-hero-caption">{clubPage.heroCaption}</p>}
              <div class="hero-actions">
                <a class="button button-primary" href={`/enquire/?venue=${encodeURIComponent(club.slug)}`}>
                  Enquire Today
                </a>
                {clubPage.primaryCtas.slice(0, 2).map((cta) => (
                  <a class="button button-secondary" href={cta.href} target="_blank" rel="noreferrer">
                    {cta.label}
                  </a>
                ))}
                {!clubPage.primaryCtas.length && clubPage.websiteHref && (
                  <a class="button button-secondary" href={clubPage.websiteHref} target="_blank" rel="noreferrer">
                    Visit venue website
                  </a>
                )}
                <a class="button button-secondary" href="/venues/">Back to venues</a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="section section-tight club-info-band-section">
        <div class="club-info-band">
          {clubPage.address && (
            <article class="club-info-item">
              <span class="filter-label">Address</span>
              <strong>{clubPage.address}</strong>
            </article>
          )}
          {clubPage.websiteUrl && (
            <article class="club-info-item">
              <span class="filter-label">Website</span>
              <strong>
                <a
                  class="text-link"
                  href={clubPage.websiteHref ?? `https://${clubPage.websiteUrl.replace(/^https?:\/\//, "")}`}
                  target="_blank"
                  rel="noreferrer"
                >
                  {clubPage.websiteUrl}
                </a>
              </strong>
            </article>
          )}
          {clubPage.nonMatchday && (
            <article class="club-info-item">
              <span class="filter-label">Non-matchday events</span>
              <strong>{clubPage.nonMatchday.phone ?? "Phone on request"}</strong>
              {clubPage.nonMatchday.email && <p>{clubPage.nonMatchday.email}</p>}
            </article>
          )}
          {clubPage.matchday && (
            <article class="club-info-item">
              <span class="filter-label">Matchday hospitality</span>
              <strong>{clubPage.matchday.phone ?? "Phone on request"}</strong>
              {clubPage.matchday.email && <p>{clubPage.matchday.email}</p>}
            </article>
          )}
        </div>
      </section>

      {sectionLinks.length ? (
        <section class="section section-tight club-anchor-section">
          <div class="pill-grid">
            {sectionLinks.map((item) => (
              <a class="pill" href={item.href}>{item.label}</a>
            ))}
          </div>
        </section>
      ) : null}

      <section class="section section-tight">
        <div class="detail-grid club-intro-grid">
          <article class="card info-card club-panel club-panel-lead">
            <p class="eyebrow">Overview</p>
            <h2 class="club-section-title">{overviewHeading}</h2>
            {(clubPage.introduction.length
              ? clubPage.introduction
              : [`Explore venue and event opportunities connected with ${club.name}, then move into a direct enquiry with Stadium Experience.`]
            ).map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </article>
          <article class="card info-card club-panel club-panel-accent club-actions-card">
            <p class="eyebrow">Quick actions</p>
            <h2 class="club-section-title">Plan your next step</h2>
            <ul class="feature-list">
              <li>Review key facts before you shortlist the venue</li>
              <li>Explore the most relevant venue sections in one place</li>
              <li>Use direct enquiry routes and public contact details to move quickly</li>
            </ul>
            <div class="club-quick-links">
              {clubPage.primaryCtas.map((link) => (
                <a class="pill" href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
              ))}
              {clubPage.socialLinks.map((link) => (
                <a class="pill" href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
              ))}
              {!clubPage.primaryCtas.length && clubPage.tourBookingHref && (
                <a class="pill" href={clubPage.tourBookingHref} target="_blank" rel="noreferrer">
                  Book a Tour
                </a>
              )}
            </div>
          </article>
        </div>
      </section>

      {clubPage.keyFacts.length ? (
        <section class="section section-tight club-section-shell" id="key-information">
          <div class="club-facts-board">
            <div class="club-facts-intro">
              <p class="eyebrow">Key information</p>
              <h2 class="club-section-title">Planning facts</h2>
              <p class="club-section-intro">
                A quick summary of the details event buyers typically look for first when deciding
                whether to shortlist a venue.
              </p>
            </div>
            <div class="key-facts-grid">
              {clubPage.keyFacts.map((fact) => (
                <article class="card key-fact-card club-fact-card">
                  <span class="club-fact-label">{fact.label}</span>
                  <strong>{fact.value}</strong>
                </article>
              ))}
            </div>
          </div>
        </section>
      ) : null}

      {contentSections.map((section, index) => (
        <section
          class="section section-tight club-section-shell"
          id={sectionAnchorFor(section.sectionKey, index)}
        >
          <div class="section-heading club-section-heading">
            <p class="eyebrow">
              {section.eyebrow ??
                (section.sectionKey === "spaces"
                  ? "Spaces for hire"
                  : section.sectionKey === "events"
                    ? "Events"
                    : "Details")}
            </p>
            <h2 class="club-section-title">{section.heading}</h2>
            {section.intro && <p class="club-section-intro">{section.intro}</p>}
          </div>
          <div class="club-editorial-grid">
            <div class="club-editorial-copy">
              {section.items.map((item, itemIndex) => (
                <article class:list={["club-editorial-feature", itemIndex === 0 && "is-featured"]}>
                  <h3>{item.title}</h3>
                  <p>{item.body}</p>
                  {item.cta && (
                    <a class="text-link club-item-link" href={item.cta.href} target="_blank" rel="noreferrer">
                      {item.cta.label}
                    </a>
                  )}
                </article>
              ))}
              <div class="club-editorial-actions">
                <a class="button button-primary" href={`/enquire/?venue=${encodeURIComponent(club.slug)}`}>
                  Enquire Today
                </a>
              </div>
            </div>
            <div class="club-editorial-visual">
              {((section.sectionKey === "spaces" ? spacesGallery : eventsGallery).length
                ? (section.sectionKey === "spaces" ? spacesGallery : eventsGallery)
                : uniqueImageList(section.items.map((item) => item.imageUrl))).length ? (
                <>
                  <div class="club-editorial-main-image">
                    <img
                      src={((section.sectionKey === "spaces" ? spacesGallery : eventsGallery).length
                        ? (section.sectionKey === "spaces" ? spacesGallery : eventsGallery)
                        : uniqueImageList(section.items.map((item) => item.imageUrl)))[0]}
                      alt={`${section.heading} at ${clubName}`}
                      loading="lazy"
                    />
                  </div>
                  {(((section.sectionKey === "spaces" ? spacesGallery : eventsGallery).length
                    ? (section.sectionKey === "spaces" ? spacesGallery : eventsGallery)
                    : uniqueImageList(section.items.map((item) => item.imageUrl))).slice(1, 4)).length ? (
                    <div class="club-editorial-thumbs">
                      {(((section.sectionKey === "spaces" ? spacesGallery : eventsGallery).length
                        ? (section.sectionKey === "spaces" ? spacesGallery : eventsGallery)
                        : uniqueImageList(section.items.map((item) => item.imageUrl))).slice(1, 4)).map((imageUrl) => (
                        <div class="club-editorial-thumb">
                          <img src={imageUrl} alt="" loading="lazy" />
                        </div>
                      ))}
                    </div>
                  ) : null}
                </>
              ) : null}
            </div>
          </div>
        </section>
      ))}

      {clubPage.specialExperiences.length ? (
        <section class="section section-tight club-section-shell" id={experiencesAnchor}>
          <div class="section-heading club-section-heading">
            <p class="eyebrow">Experiences</p>
            <h2 class="club-section-title">Seasonal and special experiences</h2>
          </div>
          <div class="club-editorial-rows">
            {clubPage.specialExperiences.map((experience, index) => (
              <article class:list={["club-editorial-row", index % 2 === 1 && "is-reversed"]}>
                {experience.imageUrl ? (
                  <div class="club-editorial-row-image">
                    <img
                      class="context-image"
                      src={experience.imageUrl}
                      alt={experience.imageAlt ?? `${experience.title} at ${clubName}`}
                      loading="lazy"
                    />
                  </div>
                ) : null}
                <div class="club-editorial-row-copy">
                  {experience.eyebrow && <p class="eyebrow">{experience.eyebrow}</p>}
                  <h3>{experience.title}</h3>
                  {experience.summary && <p>{experience.summary}</p>}
                  {experience.body
                    .filter((paragraph) => paragraph !== experience.summary)
                    .map((paragraph) => (
                      <p>{paragraph}</p>
                    ))}
                  <div class="club-editorial-actions">
                    {experience.ctas.length ? (
                      experience.ctas.map((cta) => (
                        <a class="button button-secondary" href={cta.href} target="_blank" rel="noreferrer">{cta.label}</a>
                      ))
                    ) : (
                      <a class="button button-secondary" href={`/enquire/?venue=${encodeURIComponent(club.slug)}`}>
                        Enquire Today
                      </a>
                    )}
                  </div>
                </div>
              </article>
            ))}
          </div>
        </section>
      ) : null}

      {clubPage.mapEmbedUrl ? (
        <section class="section section-tight club-section-shell" id={mapAnchor}>
          <div class="section-heading club-section-heading">
            <p class="eyebrow">Map</p>
            <h2 class="club-section-title">Find the venue</h2>
          </div>
          <div class="club-map-layout">
            <div class="club-map-shell">
              <iframe
                class="club-map"
                title={`Map for ${club.name}`}
                src={clubPage.mapEmbedUrl}
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
              ></iframe>
            </div>
            <div class="club-map-copy">
              <h3>{overviewHeading}</h3>
              {mapNarrative.map((paragraph) => (
                <p>{paragraph}</p>
              ))}
              <div class="club-editorial-actions">
                <a class="button button-secondary" href={`/enquire/?venue=${encodeURIComponent(club.slug)}`}>
                  Enquire Today
                </a>
              </div>
            </div>
          </div>
        </section>
      ) : null}

      <section class="section section-tight">
        <div class="newsletter-band club-cta-band">
          <div>
            <p class="eyebrow">Need help choosing?</p>
            <h2>Talk to Stadium Experience about this venue or similar options.</h2>
            <p>
              If you are comparing stadium venues, we can help guide you toward the right fit for your
              event, location and guest numbers.
            </p>
          </div>
          <a class="button button-primary" href={`/enquire/?venue=${encodeURIComponent(club.slug)}`}>
            Make an enquiry
          </a>
        </div>
      </section>
    </div>
  ) : (
    <section class="page-hero">
      <p class="eyebrow">Club profile</p>
      <h1>Club not found</h1>
      <p class="lede">
        We could not find that club in the public directory. Please return to the venues page and
        choose another club.
      </p>
      <a class="button button-primary" href="/venues/">Back to venues</a>
    </section>
  )}
</BaseLayout>
