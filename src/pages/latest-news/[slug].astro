---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getNewsPostBySlug } from "../../lib/content";

const { slug } = Astro.params;
const post = slug ? await getNewsPostBySlug(slug) : undefined;

if (!post) {
  return Astro.redirect("/latest-news/");
}
---

<BaseLayout title={post.title} description={post.excerpt}>
  <article class="article">
    <p class="eyebrow">{new Date(post.publishedAt).toLocaleDateString("en-GB", { dateStyle: "long" })}</p>
    <h1>{post.title}</h1>
    <p class="lede">{post.excerpt}</p>
    <div class="article-body">
      {post.body.map((paragraph) => (
        <p>{paragraph}</p>
      ))}
    </div>
  </article>
</BaseLayout>
