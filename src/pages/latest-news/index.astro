---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { newsContentBenefits } from "../../data/site";
import { getNewsPosts } from "../../lib/content";

const posts = await getNewsPosts();
---

<BaseLayout
  title="Latest News"
  description="Editorial and member news from Stadium Experience."
>
  <section class="page-hero">
    <p class="eyebrow">Latest news</p>
    <h1>Editorial content that keeps members visible and helps the site rank.</h1>
    <p class="lede">
      News, insight and venue updates are a major visibility driver for the network,
      especially when paired with category and regional landing pages.
    </p>
  </section>

  <section class="section section-tight">
    <div class="detail-grid venue-detail-grid">
      <article class="card info-card">
        <p class="eyebrow">Why content matters</p>
        <h2>Keep the site active, useful and discoverable.</h2>
        <ul class="feature-list">
          {newsContentBenefits.map((benefit) => (
            <li>{benefit}</li>
          ))}
        </ul>
      </article>
      <article class="card info-card">
        <p class="eyebrow">Stay updated</p>
        <h2>Follow the latest venue and industry updates</h2>
        <p>
          Use editorial content to surface member news, venue launches, seasonal campaigns and
          practical advice for planners.
        </p>
        <a class="button button-primary" href="/enquire/">Ask about newsletter sign-up</a>
      </article>
    </div>
  </section>

  <section class="section section-tight">
    <div class="stack">
      {posts.map((post) => (
        <article class="card list-card list-card-rich">
          <p class="eyebrow">{new Date(post.publishedAt).toLocaleDateString("en-GB", { dateStyle: "long" })}</p>
          <h2>{post.title}</h2>
          <p>{post.excerpt}</p>
          <a class="text-link" href={`/latest-news/${post.slug}/`}>Read article</a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
