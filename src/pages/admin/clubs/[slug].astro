---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="Edit Club Page" description="Manage club page content and publishing." chrome="admin">
  <script>
    import { signOutAdminBrowserSession, verifyAdminBrowserSession } from "../../../lib/admin-browser-auth";
    import { uploadAdminMediaFile, wireAdminMediaLibraryPicker } from "../../../lib/admin-media-browser";
    import { assessImageUrl } from "../../../lib/media";
    import { slugifyClubName } from "../../../lib/club-slugs";
    import { getBrowserSupabase } from "../../../lib/supabase-browser";

    window.addEventListener("DOMContentLoaded", () => {
      const initialSlug = window.location.pathname.split("/").filter(Boolean).pop();
      const supabase = getBrowserSupabase();
      const gate = document.querySelector("[data-admin-gate]");
      const loading = document.querySelector("[data-admin-loading]");
      const denied = document.querySelector("[data-admin-denied]");
      const ready = document.querySelector("[data-admin-ready]");
      const emailElement = document.querySelector("[data-admin-email]");
      const signOutButton = document.querySelector("[data-admin-signout]");
      const editorHeading = document.querySelector("[data-editor-heading]");
      const editorMetaTitle = document.querySelector("[data-editor-meta-title]");
      const editorStatus = document.querySelector("[data-editor-status]");
      const editorStatusMessage = document.querySelector("[data-editor-status-message]");
      const inlineSaveStatus = document.querySelector("[data-inline-save-status]");
      const editorForm = document.querySelector("[data-editor-form]");
      const keyFactsList = document.querySelector("[data-key-facts-list]");
      const socialLinksList = document.querySelector("[data-social-links-list]");
      const spacesList = document.querySelector("[data-spaces-list]");
      const eventsList = document.querySelector("[data-events-list]");
      const addKeyFactButton = document.querySelector("[data-add-key-fact]");
      const addSocialLinkButton = document.querySelector("[data-add-social-link]");
      const addSpaceButton = document.querySelector("[data-add-space]");
      const addEventButton = document.querySelector("[data-add-event]");
      const liveLink = document.querySelector("[data-live-link]");
      const saveDraftButton = document.querySelector("[data-save-draft]");
      const publishButton = document.querySelector("[data-publish-record]");
      const archiveButton = document.querySelector("[data-archive-record]");
      const publishStatusLabel = document.querySelector("[data-publish-status-label]");
      const publishStatusNote = document.querySelector("[data-publish-status-note]");

      const imageFields = ["crest_url", "hero_image_url", "christmas_image_url", "play_on_pitch_image_url"];
      const imageSlots = {
        crest_url: "crest",
        hero_image_url: "hero",
        christmas_image_url: "christmas",
        play_on_pitch_image_url: "play-on-pitch"
      };
      const editorFieldNames = [
        "club_name", "club_size", "summary", "address", "latitude", "longitude", "website_url", "website_href",
        "tour_booking_href", "crest_url", "hero_image_url", "christmas_image_url", "play_on_pitch_image_url",
        "non_matchday_phone", "non_matchday_email", "matchday_phone", "matchday_email", "introduction_heading",
        "christmas_text", "play_on_pitch_text", "tours_text", "map_embed_url"
      ];

      const editorSelectClause = `
        slug, club_name, crest_url, summary, address, latitude, longitude, website_url, website_href,
        social_links, tour_booking_href, non_matchday_phone, non_matchday_email, matchday_phone,
        matchday_email, introduction_heading, introduction_paragraphs, spaces, events, christmas_text,
        play_on_pitch_text, tours_text, key_facts, map_embed_url, hero_image_url, christmas_image_url,
        play_on_pitch_image_url, club_size, published, archived, created_at, updated_at
      `;

      const editorFallbackSelectClause = `
        slug, club_name, crest_url, summary, address, latitude, longitude, website_url, website_href,
        social_links, tour_booking_href, non_matchday_phone, non_matchday_email, matchday_phone,
        matchday_email, introduction_heading, introduction_paragraphs, spaces, events, christmas_text,
        play_on_pitch_text, tours_text, key_facts, map_embed_url, hero_image_url, christmas_image_url,
        play_on_pitch_image_url, club_size, published, created_at, updated_at
      `;

      let currentSlug = initialSlug;
      let currentRecord = null;
      const mediaLibraryCache = new Map();

      const setState = (state) => {
        loading.hidden = state !== "loading";
        denied.hidden = state !== "denied";
        ready.hidden = state !== "ready";
      };

      const redirectToLogin = () => {
        window.location.href = "/admin/login/";
      };

      const setStatusMessage = (message, isError = false) => {
        if (!editorStatusMessage) return;
        editorStatusMessage.textContent = message;
        editorStatusMessage.classList.toggle("is-error", isError);
      };

      const setInlineSaveMessage = (message, isError = false) => {
        if (!inlineSaveStatus) return;
        inlineSaveStatus.textContent = message;
        inlineSaveStatus.classList.toggle("is-error", isError);
      };

      const asString = (value) => (typeof value === "string" ? value : "");
      const asNullableString = (value) => {
        const text = asString(value).trim();
        return text || null;
      };

      const asNullableNumber = (value) => {
        const text = String(value ?? "").trim();
        if (!text) return null;
        const number = Number(text);
        return Number.isFinite(number) ? number : null;
      };

      const normaliseClubSize = (value) => {
        const text = String(value ?? "").trim().toLowerCase();
        return text === "small" || text === "medium" || text === "large" ? text : null;
      };

      const formatClubSize = (value) => {
        const normalised = normaliseClubSize(value);
        return normalised ? `${normalised.charAt(0).toUpperCase()}${normalised.slice(1)}` : "";
      };

      const splitParagraphs = (value) =>
        String(value ?? "").replace(/\r\n/g, "\n").split(/\n\s*\n/g).map((paragraph) => paragraph.trim()).filter(Boolean);

      const joinParagraphs = (value) =>
        Array.isArray(value) ? value.filter(Boolean).join("\n\n") : "";

      const asLinkArray = (value) =>
        Array.isArray(value)
          ? value.map((item) => {
              if (!item || typeof item !== "object") return null;
              const label = asNullableString(item.label);
              const href = asNullableString(item.href);
              return label && href ? { label, href } : null;
            }).filter(Boolean)
          : [];

      const asContentBlocks = (value) =>
        Array.isArray(value)
          ? value.map((item) => {
              if (!item || typeof item !== "object") return null;
              const title = asNullableString(item.title);
              const body = asNullableString(item.body);
              return title && body ? { title, body } : null;
            }).filter(Boolean)
          : [];

      const asKeyFacts = (value) =>
        Array.isArray(value)
          ? value.map((item) => {
              if (!item || typeof item !== "object") return null;
              const label = asNullableString(item.label);
              const factValue = asNullableString(item.value);
              return label && factValue ? { label, value: factValue } : null;
            }).filter(Boolean)
          : [];

      const normaliseRecord = (row) => ({
        slug: asNullableString(row?.slug) ?? currentSlug ?? "",
        club_name: asString(row?.club_name),
        club_size: formatClubSize(row?.club_size),
        summary: asNullableString(row?.summary),
        address: asNullableString(row?.address),
        latitude: row?.latitude == null ? "" : String(row.latitude),
        longitude: row?.longitude == null ? "" : String(row.longitude),
        website_url: asNullableString(row?.website_url),
        website_href: asNullableString(row?.website_href),
        social_links: asLinkArray(row?.social_links),
        tour_booking_href: asNullableString(row?.tour_booking_href),
        crest_url: asNullableString(row?.crest_url),
        hero_image_url: asNullableString(row?.hero_image_url),
        christmas_image_url: asNullableString(row?.christmas_image_url),
        play_on_pitch_image_url: asNullableString(row?.play_on_pitch_image_url),
        non_matchday_phone: asNullableString(row?.non_matchday_phone),
        non_matchday_email: asNullableString(row?.non_matchday_email),
        matchday_phone: asNullableString(row?.matchday_phone),
        matchday_email: asNullableString(row?.matchday_email),
        introduction_heading: asNullableString(row?.introduction_heading),
        introduction_paragraphs: Array.isArray(row?.introduction_paragraphs) ? row.introduction_paragraphs : [],
        spaces: asContentBlocks(row?.spaces),
        events: asContentBlocks(row?.events),
        christmas_text: asNullableString(row?.christmas_text),
        play_on_pitch_text: asNullableString(row?.play_on_pitch_text),
        tours_text: asNullableString(row?.tours_text),
        key_facts: asKeyFacts(row?.key_facts),
        map_embed_url: asNullableString(row?.map_embed_url),
        published: row?.published === true,
        archived: row?.archived === true
      });

      const assignField = (name, value) => {
        const field = editorForm?.elements.namedItem(name);
        if (field && "value" in field) {
          field.value = value ?? "";
        }
      };

      const renderImagePreview = (name, value) => {
        const preview = document.querySelector(`[data-image-preview="${name}"]`);
        if (!preview) return;
        const url = asNullableString(value);
        preview.classList.toggle("has-image", Boolean(url));
        preview.replaceChildren();

        if (!url) {
          const placeholder = document.createElement("span");
          placeholder.textContent = "No image added yet";
          preview.appendChild(placeholder);
          return;
        }

        const image = document.createElement("img");
        image.src = url;
        image.alt = "";
        image.loading = "lazy";
        image.addEventListener("error", () => {
          preview.classList.remove("has-image");
          preview.replaceChildren();
          const placeholder = document.createElement("span");
          placeholder.textContent = "Could not load image preview";
          preview.appendChild(placeholder);
        });
        preview.appendChild(image);
      };

      const renderImageAdvice = (name, value) => {
        const note = document.querySelector(`[data-image-advice="${name}"]`);

        if (!note) {
          return;
        }

        const assessment = assessImageUrl(value);
        note.textContent = assessment.guidance;
        note.classList.toggle("is-warning", assessment.kind === "legacy-wordpress" || assessment.kind === "external" || assessment.kind === "invalid");
        note.classList.toggle("is-positive", assessment.isOwned && assessment.kind !== "empty");
      };

      const setUploadStatus = (name, message, isError = false) => {
        const element = document.querySelector(`[data-upload-status="${name}"]`);

        if (!element) {
          return;
        }

        element.textContent = message;
        element.classList.toggle("is-error", isError);
      };

      const setLibraryStatus = (name, message, isError = false) => {
        const element = document.querySelector(`[data-library-status="${name}"]`);

        if (!element) {
          return;
        }

        element.textContent = message;
        element.classList.toggle("is-error", isError);
      };

      const getMediaLibraryTarget = (fieldName) => {
        const clubName = asNullableString(editorForm?.elements.namedItem("club_name")?.value);
        const clubSlug = currentSlug || slugifyClubName(clubName || initialSlug || "club");

        return {
          kind: "club",
          clubSlug,
          slot: imageSlots[fieldName] ?? "hero"
        };
      };

      const getMediaLibraryCacheKey = (fieldName) => {
        const target = getMediaLibraryTarget(fieldName);
        return `${target.kind}:${target.clubSlug}`;
      };

      const createKeyFactRow = (fact = { label: "", value: "" }) => {
        const row = document.createElement("div");
        row.className = "admin-repeater-row";
        row.setAttribute("data-key-fact-row", "true");
        row.innerHTML = `<label class="admin-repeater-field"><span>Label</span><input type="text" data-key-fact-label placeholder="Capacity" /></label><label class="admin-repeater-field"><span>Value</span><input type="text" data-key-fact-value placeholder="Up to 500 guests" /></label>`;
        const removeButton = document.createElement("button");
        removeButton.className = "button button-danger button-compact";
        removeButton.type = "button";
        removeButton.textContent = "Remove";
        removeButton.addEventListener("click", () => row.remove());
        row.querySelector("[data-key-fact-label]").value = fact.label ?? "";
        row.querySelector("[data-key-fact-value]").value = fact.value ?? "";
        row.appendChild(removeButton);
        return row;
      };

      const createSocialLinkRow = (link = { label: "", href: "" }) => {
        const row = document.createElement("div");
        row.className = "admin-repeater-row";
        row.setAttribute("data-social-link-row", "true");
        row.innerHTML = `<label class="admin-repeater-field"><span>Label</span><input type="text" data-social-link-label placeholder="Instagram" /></label><label class="admin-repeater-field"><span>Link</span><input type="url" data-social-link-href placeholder="https://..." /></label>`;
        const removeButton = document.createElement("button");
        removeButton.className = "button button-danger button-compact";
        removeButton.type = "button";
        removeButton.textContent = "Remove";
        removeButton.addEventListener("click", () => row.remove());
        row.querySelector("[data-social-link-label]").value = link.label ?? "";
        row.querySelector("[data-social-link-href]").value = link.href ?? "";
        row.appendChild(removeButton);
        return row;
      };

      const createContentBlockRow = (type, block = { title: "", body: "" }) => {
        const row = document.createElement("div");
        row.className = "admin-repeater-row";
        row.setAttribute(`data-${type}-row`, "true");
        row.innerHTML = `<label class="admin-repeater-field"><span>Title</span><input type="text" data-${type}-title placeholder="Executive boxes" /></label><label class="admin-repeater-field full-width"><span>Body</span><textarea rows="5" data-${type}-body placeholder="Describe this section in a clear, public-facing way."></textarea></label>`;
        const removeButton = document.createElement("button");
        removeButton.className = "button button-danger button-compact";
        removeButton.type = "button";
        removeButton.textContent = "Remove";
        removeButton.addEventListener("click", () => row.remove());
        row.querySelector(`[data-${type}-title]`).value = block.title ?? "";
        row.querySelector(`[data-${type}-body]`).value = block.body ?? "";
        row.appendChild(removeButton);
        return row;
      };

      const renderRepeater = (list, createRow, values, emptyValue) => {
        if (!list) return;
        const fragment = document.createDocumentFragment();
        (values.length ? values : [emptyValue]).forEach((value) => fragment.appendChild(createRow(value)));
        list.replaceChildren(fragment);
      };

      const collectKeyFacts = () =>
        Array.from(keyFactsList?.querySelectorAll("[data-key-fact-row]") ?? [])
          .map((row) => {
            const label = asNullableString(row.querySelector("[data-key-fact-label]")?.value);
            const value = asNullableString(row.querySelector("[data-key-fact-value]")?.value);
            return label && value ? { label, value } : null;
          })
          .filter(Boolean);

      const collectSocialLinks = () =>
        Array.from(socialLinksList?.querySelectorAll("[data-social-link-row]") ?? [])
          .map((row) => {
            const label = asNullableString(row.querySelector("[data-social-link-label]")?.value);
            const href = asNullableString(row.querySelector("[data-social-link-href]")?.value);
            return label && href ? { label, href } : null;
          })
          .filter(Boolean);

      const collectBlocks = (list, type) =>
        Array.from(list?.querySelectorAll(`[data-${type}-row]`) ?? [])
          .map((row) => {
            const title = asNullableString(row.querySelector(`[data-${type}-title]`)?.value);
            const body = asNullableString(row.querySelector(`[data-${type}-body]`)?.value);
            return title && body ? { title, body } : null;
          })
          .filter(Boolean);

      const getPayload = () => {
        const clubName = asNullableString(editorForm?.elements.namedItem("club_name")?.value);

        if (!clubName) {
          throw new Error("Please enter the club name first.");
        }

        return {
          slug: slugifyClubName(clubName),
          club_name: clubName,
          club_size: normaliseClubSize(editorForm?.elements.namedItem("club_size")?.value),
          summary: asNullableString(editorForm?.elements.namedItem("summary")?.value),
          address: asNullableString(editorForm?.elements.namedItem("address")?.value),
          latitude: asNullableNumber(editorForm?.elements.namedItem("latitude")?.value),
          longitude: asNullableNumber(editorForm?.elements.namedItem("longitude")?.value),
          website_url: asNullableString(editorForm?.elements.namedItem("website_url")?.value),
          website_href: asNullableString(editorForm?.elements.namedItem("website_href")?.value),
          social_links: collectSocialLinks(),
          tour_booking_href: asNullableString(editorForm?.elements.namedItem("tour_booking_href")?.value),
          crest_url: asNullableString(editorForm?.elements.namedItem("crest_url")?.value),
          hero_image_url: asNullableString(editorForm?.elements.namedItem("hero_image_url")?.value),
          christmas_image_url: asNullableString(editorForm?.elements.namedItem("christmas_image_url")?.value),
          play_on_pitch_image_url: asNullableString(editorForm?.elements.namedItem("play_on_pitch_image_url")?.value),
          non_matchday_phone: asNullableString(editorForm?.elements.namedItem("non_matchday_phone")?.value),
          non_matchday_email: asNullableString(editorForm?.elements.namedItem("non_matchday_email")?.value),
          matchday_phone: asNullableString(editorForm?.elements.namedItem("matchday_phone")?.value),
          matchday_email: asNullableString(editorForm?.elements.namedItem("matchday_email")?.value),
          introduction_heading: asNullableString(editorForm?.elements.namedItem("introduction_heading")?.value),
          introduction_paragraphs: splitParagraphs(editorForm?.elements.namedItem("introduction_paragraphs")?.value),
          spaces: collectBlocks(spacesList, "space"),
          events: collectBlocks(eventsList, "event"),
          christmas_text: asNullableString(editorForm?.elements.namedItem("christmas_text")?.value),
          play_on_pitch_text: asNullableString(editorForm?.elements.namedItem("play_on_pitch_text")?.value),
          tours_text: asNullableString(editorForm?.elements.namedItem("tours_text")?.value),
          key_facts: collectKeyFacts(),
          map_embed_url: asNullableString(editorForm?.elements.namedItem("map_embed_url")?.value)
        };
      };

      const fillForm = (record) => {
        if (!editorForm || !record) return;
        editorFieldNames.forEach((fieldName) => assignField(fieldName, record[fieldName] ?? ""));
        assignField("introduction_paragraphs", joinParagraphs(record.introduction_paragraphs));
        renderRepeater(keyFactsList, createKeyFactRow, record.key_facts ?? [], { label: "", value: "" });
        renderRepeater(socialLinksList, createSocialLinkRow, record.social_links ?? [], { label: "", href: "" });
        renderRepeater(spacesList, (value) => createContentBlockRow("space", value), record.spaces ?? [], { title: "", body: "" });
        renderRepeater(eventsList, (value) => createContentBlockRow("event", value), record.events ?? [], { title: "", body: "" });
        imageFields.forEach((fieldName) => {
          renderImagePreview(fieldName, record[fieldName]);
          renderImageAdvice(fieldName, record[fieldName]);
        });
      };

      const updateWorkflowUi = (record) => {
        if (!record) return;
        const isArchived = record.archived === true;
        const isPublished = record.published === true;
        const label = isArchived ? "Archived" : isPublished ? "Published" : "Draft";

        if (editorHeading) editorHeading.textContent = record.club_name || "Untitled club";
        if (editorMetaTitle) editorMetaTitle.textContent = `${record.club_name || "Untitled club"} page`;
        if (editorStatus) {
          editorStatus.textContent = label;
          editorStatus.classList.toggle("is-draft", label === "Draft");
          editorStatus.classList.toggle("is-published", label === "Published");
          editorStatus.classList.toggle("is-archived", label === "Archived");
        }

        if (publishStatusLabel) {
          publishStatusLabel.textContent = isArchived ? "Archived club page" : isPublished ? "Published club page" : "Draft club page";
        }

        if (publishStatusNote) {
          publishStatusNote.textContent = isArchived
            ? "This club is hidden from the public site until you restore it and publish again."
            : isPublished
              ? "This version is live on the public club page."
              : "Save a draft while you edit, then publish when the page is ready.";
        }

        if (archiveButton) {
          archiveButton.textContent = isArchived ? "Restore record" : "Archive record";
          archiveButton.classList.toggle("button-secondary", isArchived);
          archiveButton.classList.toggle("button-danger", !isArchived);
        }

        if (liveLink) {
          liveLink.hidden = !isPublished || isArchived || !record.slug;
          liveLink.href = `/clubs/${record.slug}/`;
        }
      };

      const setBusyState = (busy) => {
        [saveDraftButton, publishButton, archiveButton].forEach((button) => {
          if (button) button.disabled = busy;
        });
        if (!busy && currentRecord) {
          updateWorkflowUi(currentRecord);
        }
      };

      const loadRecord = async () => {
        const primaryQuery = await supabase.from("club_pages").select(editorSelectClause).eq("slug", currentSlug).maybeSingle();
        if (!primaryQuery.error && primaryQuery.data) {
          return normaliseRecord(primaryQuery.data);
        }

        const fallbackQuery = await supabase.from("club_pages").select(editorFallbackSelectClause).eq("slug", currentSlug).maybeSingle();
        if (fallbackQuery.error) {
          throw new Error(fallbackQuery.error.message);
        }
        if (!fallbackQuery.data) {
          throw new Error("Club record not found.");
        }

        return normaliseRecord({ ...fallbackQuery.data, archived: false });
      };

      const handleSlugRedirect = (nextSlug) => {
        if (!nextSlug || nextSlug === currentSlug) return false;
        window.location.href = `/admin/clubs/${nextSlug}/`;
        return true;
      };

      const saveRecord = async (published) => {
        const payload = getPayload();
        const updatePayload = { ...payload, published, archived: false, updated_at: new Date().toISOString() };
        const { data, error } = await supabase
          .from("club_pages")
          .update(updatePayload)
          .eq("slug", currentSlug)
          .select(editorSelectClause)
          .single();

        if (error || !data) {
          throw new Error(error?.message ?? "Unable to save this club page.");
        }

        currentRecord = normaliseRecord(data);
        fillForm(currentRecord);
        updateWorkflowUi(currentRecord);
        if (handleSlugRedirect(currentRecord.slug)) return;
        currentSlug = currentRecord.slug;
      };

      const toggleArchived = async () => {
        const nextArchived = !(currentRecord?.archived === true);
        const confirmationMessage = nextArchived
          ? `Archive ${currentRecord?.club_name ?? "this club"}? You can restore it later.`
          : `Restore ${currentRecord?.club_name ?? "this club"} so you can continue editing and publish again?`;

        if (!window.confirm(confirmationMessage)) return;

        const { data, error } = await supabase
          .from("club_pages")
          .update({ archived: nextArchived, published: false, updated_at: new Date().toISOString() })
          .eq("slug", currentSlug)
          .select(editorSelectClause)
          .single();

        if (error || !data) {
          throw new Error(error?.message ?? "Unable to update the archive state.");
        }

        currentRecord = normaliseRecord(data);
        fillForm(currentRecord);
        updateWorkflowUi(currentRecord);
      };

      const wireImagePreviews = () => {
        imageFields.forEach((fieldName) => {
          const field = editorForm?.elements.namedItem(fieldName);
          field?.addEventListener("input", () => {
            renderImagePreview(fieldName, field.value);
            renderImageAdvice(fieldName, field.value);
          });
        });
      };

      const wireImageUploads = () => {
        imageFields.forEach((fieldName) => {
          const input = document.querySelector(`[data-upload-input="${fieldName}"]`);
          const button = document.querySelector(`[data-upload-button="${fieldName}"]`);

          if (!input || !button) {
            return;
          }

          button.addEventListener("click", async () => {
            const file = input.files?.[0];

            if (!file) {
              setUploadStatus(fieldName, "Choose an image file first.", true);
              return;
            }

            const clubName = asNullableString(editorForm?.elements.namedItem("club_name")?.value) ?? currentSlug ?? "club";
            const clubSlug = slugifyClubName(clubName);

            button.disabled = true;
            setUploadStatus(fieldName, "Uploading image...");

            try {
              const uploaded = await uploadAdminMediaFile({
                file,
                target: {
                  kind: "club",
                  clubSlug,
                  slot: imageSlots[fieldName]
                }
              }, supabase);

              assignField(fieldName, uploaded.url);
              renderImagePreview(fieldName, uploaded.url);
              renderImageAdvice(fieldName, uploaded.url);
              mediaLibraryCache.delete(getMediaLibraryCacheKey(fieldName));
              setUploadStatus(fieldName, "Image uploaded.");
              input.value = "";
            } catch (error) {
              setUploadStatus(fieldName, error instanceof Error ? error.message : "Unable to upload the image.", true);
            } finally {
              button.disabled = false;
            }
          });
        });
      };

      const wireMediaLibraryPickers = () => {
        imageFields.forEach((fieldName) => {
          wireAdminMediaLibraryPicker({
            cache: mediaLibraryCache,
            fieldName,
            getCacheKey: () => getMediaLibraryCacheKey(fieldName),
            getCurrentValue: () => editorForm?.elements.namedItem(fieldName)?.value ?? "",
            getTarget: () => getMediaLibraryTarget(fieldName),
            onSelect: (item) => {
              assignField(fieldName, item.url);
              renderImagePreview(fieldName, item.url);
              renderImageAdvice(fieldName, item.url);
            },
            setStatus: (message, isError = false) => setLibraryStatus(fieldName, message, isError),
            supabase
          });
        });
      };

      if (!supabase || !gate || !initialSlug) {
        setState("denied");
      } else {
        verifyAdminBrowserSession(supabase).then(async (verifiedSession) => {
          if (!verifiedSession.ok) {
            setState("denied");
            redirectToLogin();
            return;
          }

          if (emailElement) {
            emailElement.textContent = verifiedSession.email ?? "";
          }

          try {
            currentRecord = await loadRecord();
            fillForm(currentRecord);
            updateWorkflowUi(currentRecord);
            setStatusMessage("Club page loaded.");
            setState("ready");
          } catch (error) {
            console.error("Unable to load club record", error);
            setStatusMessage(error instanceof Error ? error.message : "Unable to load this club record.", true);
            setState("ready");
          }
        });

        wireImagePreviews();
        wireImageUploads();
        wireMediaLibraryPickers();
        addKeyFactButton?.addEventListener("click", () => keyFactsList?.appendChild(createKeyFactRow()));
        addSocialLinkButton?.addEventListener("click", () => socialLinksList?.appendChild(createSocialLinkRow()));
        addSpaceButton?.addEventListener("click", () => spacesList?.appendChild(createContentBlockRow("space")));
        addEventButton?.addEventListener("click", () => eventsList?.appendChild(createContentBlockRow("event")));

        saveDraftButton?.addEventListener("click", async () => {
          setBusyState(true);
          setInlineSaveMessage("Saving draft...");
          try {
            await saveRecord(false);
            setStatusMessage("Draft saved.");
            setInlineSaveMessage("Draft saved.");
          } catch (error) {
            setStatusMessage(error instanceof Error ? error.message : "Unable to save this draft.", true);
            setInlineSaveMessage("Draft save failed.", true);
          } finally {
            setBusyState(false);
          }
        });

        publishButton?.addEventListener("click", async () => {
          setBusyState(true);
          setInlineSaveMessage("Publishing record...");
          try {
            await saveRecord(true);
            setStatusMessage("Club page published.");
            setInlineSaveMessage("Published successfully.");
          } catch (error) {
            setStatusMessage(error instanceof Error ? error.message : "Unable to publish this club page.", true);
            setInlineSaveMessage("Publish failed.", true);
          } finally {
            setBusyState(false);
          }
        });

        archiveButton?.addEventListener("click", async () => {
          setBusyState(true);
          setInlineSaveMessage(currentRecord?.archived ? "Restoring record..." : "Archiving record...");
          try {
            await toggleArchived();
            setStatusMessage(currentRecord?.archived ? "Club record archived." : "Club record restored as a draft.");
            setInlineSaveMessage(currentRecord?.archived ? "Record archived." : "Record restored.");
          } catch (error) {
            setStatusMessage(error instanceof Error ? error.message : "Unable to update the archive state.", true);
            setInlineSaveMessage("Archive update failed.", true);
          } finally {
            setBusyState(false);
          }
        });

        signOutButton?.addEventListener("click", async () => {
          await signOutAdminBrowserSession(supabase);
          redirectToLogin();
        });
      }
    });
  </script>
