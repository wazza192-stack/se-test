---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="Admin News" description="Manage Stadium Experience news articles." chrome="admin">
  <section class="page-hero page-hero-tight">
    <p class="eyebrow">Admin</p>
    <h1>Latest News</h1>
    <p class="lede">
      Create, edit and publish editorial updates so the public news section stays active and useful.
    </p>
  </section>

  <section class="section section-tight">
    <div class="admin-gate" data-admin-gate>
      <div class="directory-message-card" data-admin-loading>
        <p class="eyebrow">Checking access</p>
        <h3>Verifying your session.</h3>
        <p>Please wait while we confirm your admin login.</p>
      </div>

      <div class="directory-message-card" data-admin-denied hidden>
        <p class="eyebrow">Sign-in required</p>
        <h3>You need to sign in before accessing the admin area.</h3>
        <p><a class="text-link" href="/admin/login/">Go to admin login</a></p>
      </div>

      <div class="admin-dashboard" data-admin-ready hidden>
        <div class="admin-toolbar">
          <div>
            <p class="eyebrow">Signed in</p>
            <h2 class="club-section-title">News dashboard</h2>
            <p class="admin-user-email" data-admin-email></p>
          </div>
          <button class="button button-secondary" type="button" data-admin-signout>Sign out</button>
        </div>

        <nav class="admin-page-tabs" aria-label="Admin sections">
          <a class="admin-page-tab" href="/admin/">Club data</a>
          <a class="admin-page-tab" href="/admin/jobs/">Stadium Jobs</a>
          <a class="admin-page-tab is-active" href="/admin/news/" aria-current="page">Latest News</a>
        </nav>

        <div class="admin-shell">
          <section class="card admin-card admin-jobs-card">
            <div class="admin-section-heading">
              <div>
                <p class="eyebrow">Editorial</p>
                <h3>Manage latest news</h3>
              </div>
              <a class="text-link" href="/latest-news/">View news page</a>
            </div>

            <p>
              Start each article as a draft, refine the summary and body copy in the editor, then
              publish when it is ready for the live site.
            </p>

            <form class="admin-create-form admin-job-create-form" data-news-create-form>
              <label>
                Article title *
                <input
                  type="text"
                  name="newsTitle"
                  placeholder="Spring venue updates from across the network"
                  autocomplete="off"
                  required
                />
              </label>
              <label>
                Publish date *
                <input type="date" name="newsPublishDate" required />
              </label>
              <button class="button button-primary" type="submit">Create draft article</button>
            </form>

            <p class="admin-auth-status" data-news-create-status></p>

            <div class="admin-list-state" data-admin-news-loading>
              <p>Loading the news list.</p>
            </div>

            <div class="admin-list-state" data-admin-news-empty hidden>
              <p>No news articles exist yet. Create your first draft above.</p>
            </div>

            <div class="admin-list-state" data-admin-news-error hidden>
              <p>We could not load the news list right now.</p>
            </div>

            <div class="admin-table-wrap" data-admin-news-list hidden>
              <table class="admin-club-table">
                <thead>
                  <tr>
                    <th>Article</th>
                    <th>Status</th>
                    <th>Publish date</th>
                    <th>Updated</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody data-admin-news-body></tbody>
              </table>
            </div>
          </section>
        </div>
      </div>
    </div>
  </section>

  <script>
    import { signOutAdminBrowserSession, verifyAdminBrowserSession } from "../../../lib/admin-browser-auth";
    import { slugifyNewsPostTitle } from "../../../lib/news-posts";
    import { getBrowserSupabase } from "../../../lib/supabase-browser";

    const supabase = getBrowserSupabase();
    const gate = document.querySelector("[data-admin-gate]");
    const loading = document.querySelector("[data-admin-loading]");
    const denied = document.querySelector("[data-admin-denied]");
    const ready = document.querySelector("[data-admin-ready]");
    const emailElement = document.querySelector("[data-admin-email]");
    const signOutButton = document.querySelector("[data-admin-signout]");
    const newsCreateForm = document.querySelector("[data-news-create-form]");
    const newsCreateStatus = document.querySelector("[data-news-create-status]");
    const newsLoading = document.querySelector("[data-admin-news-loading]");
    const newsEmpty = document.querySelector("[data-admin-news-empty]");
    const newsError = document.querySelector("[data-admin-news-error]");
    const newsList = document.querySelector("[data-admin-news-list]");
    const newsTableBody = document.querySelector("[data-admin-news-body]");
    let allNews = [];

    const setState = (state) => {
      loading.hidden = state !== "loading";
      denied.hidden = state !== "denied";
      ready.hidden = state !== "ready";
    };

    const setNewsState = (state) => {
      if (newsLoading) newsLoading.hidden = state !== "loading";
      if (newsEmpty) newsEmpty.hidden = state !== "empty";
      if (newsError) newsError.hidden = state !== "error";
      if (newsList) newsList.hidden = state !== "ready";
    };

    const redirectToLogin = () => {
      window.location.href = "/admin/login/";
    };

    const getNewsStatusClass = (article) => (article.published ? "is-published" : "is-draft");
    const getNewsStatusLabel = (article) => (article.published ? "Published" : "Draft");

    const createNewsRow = (article) => {
      const row = document.createElement("tr");
      row.className = "admin-club-table-row";

      const articleCell = document.createElement("td");
      const articleHeading = document.createElement("div");
      articleHeading.className = "admin-club-table-heading";
      const title = document.createElement("strong");
      title.textContent = article.title || "Untitled article";
      const meta = document.createElement("span");
      meta.textContent = article.excerpt || "Summary still to be added.";
      articleHeading.append(title, meta);
      articleCell.appendChild(articleHeading);

      const statusCell = document.createElement("td");
      const status = document.createElement("span");
      status.className = `admin-status-pill ${getNewsStatusClass(article)}`;
      status.textContent = getNewsStatusLabel(article);
      statusCell.appendChild(status);

      const publishDateCell = document.createElement("td");
      publishDateCell.textContent = article.published_at
        ? new Date(article.published_at).toLocaleDateString("en-GB", { dateStyle: "medium" })
        : "No date set";

      const updatedCell = document.createElement("td");
      updatedCell.textContent = article.updated_at
        ? new Date(article.updated_at).toLocaleString("en-GB")
        : "Not yet updated";

      const actionsCell = document.createElement("td");
      const actions = document.createElement("div");
      actions.className = "admin-club-actions";
      actions.innerHTML = `
        <a class="button button-primary button-compact" href="/admin/news/${article.slug}/">Edit article</a>
        <button class="button button-danger button-compact admin-delete-news-button" type="button">Delete</button>
      `;

      const deleteButton = actions.querySelector(".admin-delete-news-button");
      deleteButton?.addEventListener("click", async () => {
        const confirmed = window.confirm(`Delete ${article.title}? This will remove the article from the site.`);

        if (!confirmed) {
          return;
        }

        try {
          const { error } = await supabase.from("news_posts").delete().eq("slug", article.slug);

          if (error) {
            throw new Error(error.message);
          }

          allNews = allNews.filter((entry) => entry.slug !== article.slug);
          renderNewsList();
        } catch (error) {
          window.alert(error instanceof Error ? error.message : "Unable to delete this article.");
        }
      });

      actionsCell.appendChild(actions);
      row.append(articleCell, statusCell, publishDateCell, updatedCell, actionsCell);
      return row;
    };

    const renderNewsList = () => {
      if (!newsTableBody) {
        return;
      }

      if (!allNews.length) {
        newsTableBody.replaceChildren();
        setNewsState("empty");
        return;
      }

      const fragment = document.createDocumentFragment();
      allNews.forEach((article) => fragment.appendChild(createNewsRow(article)));
      newsTableBody.replaceChildren(fragment);
      setNewsState("ready");
    };

    const loadNewsList = async () => {
      if (!newsList || !newsTableBody) {
        return;
      }

      setNewsState("loading");

      try {
        const { data, error } = await supabase
          .from("news_posts")
          .select("slug, title, excerpt, published, published_at, updated_at")
          .order("published_at", { ascending: false })
          .order("updated_at", { ascending: false });

        if (error) {
          throw new Error(error.message);
        }

        allNews = Array.isArray(data) ? data : [];
        renderNewsList();
      } catch (error) {
        console.error("Unable to load admin news", error);
        setNewsState("error");
      }
    };

    if (!supabase || !gate) {
      setState("denied");
    } else {
      verifyAdminBrowserSession(supabase).then((verifiedSession) => {
        if (!verifiedSession.ok) {
          setState("denied");
          redirectToLogin();
          return;
        }

        if (emailElement) {
          emailElement.textContent = verifiedSession.email ?? "";
        }

        setState("ready");
        loadNewsList();
      });

      newsCreateForm?.addEventListener("submit", async (event) => {
        event.preventDefault();

        const form = new FormData(newsCreateForm);
        const title = String(form.get("newsTitle") ?? "").trim();
        const publishDate = String(form.get("newsPublishDate") ?? "").trim();

        if (!title || !publishDate) {
          if (newsCreateStatus) {
            newsCreateStatus.textContent = "Please complete the title and publish date first.";
            newsCreateStatus.classList.add("is-error");
          }
          return;
        }

        if (newsCreateStatus) {
          newsCreateStatus.textContent = "Creating your new draft article.";
          newsCreateStatus.classList.remove("is-error");
        }

        try {
          const slug = slugifyNewsPostTitle(title);
          const { data: existing, error: existingError } = await supabase
            .from("news_posts")
            .select("slug")
            .eq("slug", slug)
            .maybeSingle();

          if (existingError) {
            throw new Error(existingError.message);
          }

          if (existing?.slug) {
            throw new Error("An article with that title already exists.");
          }

          const { data: draft, error } = await supabase
            .from("news_posts")
            .insert({
              slug,
              title,
              excerpt: null,
              body: null,
              cover_image_url: null,
              seo: null,
              published: false,
              published_at: publishDate
            })
            .select("slug, title")
            .single();

          if (error || !draft) {
            throw new Error(error?.message ?? "Unable to create article");
          }

          if (newsCreateStatus) {
            newsCreateStatus.textContent = `Draft created for ${draft.title}. Opening the editor.`;
            newsCreateStatus.classList.remove("is-error");
          }

          window.location.href = `/admin/news/${draft.slug}/`;
        } catch (error) {
          if (newsCreateStatus) {
            newsCreateStatus.textContent = error instanceof Error ? error.message : "Unable to create the article draft.";
            newsCreateStatus.classList.add("is-error");
          }
        }
      });

      signOutButton?.addEventListener("click", async () => {
        await signOutAdminBrowserSession(supabase);
        redirectToLogin();
      });
    }
  </script>
</BaseLayout>
