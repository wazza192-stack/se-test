---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Admin" description="Stadium Experience admin area." chrome="admin">
  <section class="page-hero page-hero-tight">
    <p class="eyebrow">Admin</p>
    <h1>Website admin</h1>
    <p class="lede">
      A simple starting point for signed-in content editors. This can grow into a fuller website
      management area over time.
    </p>
  </section>

  <section class="section section-tight">
    <div class="admin-gate" data-admin-gate>
      <div class="directory-message-card" data-admin-loading>
        <p class="eyebrow">Checking access</p>
        <h3>Verifying your session.</h3>
        <p>Please wait while we confirm your admin login.</p>
      </div>

      <div class="directory-message-card" data-admin-denied hidden>
        <p class="eyebrow">Sign-in required</p>
        <h3>You need to sign in before accessing the admin area.</h3>
        <p><a class="text-link" href="/admin/login/">Go to admin login</a></p>
      </div>

      <div class="admin-dashboard" data-admin-ready hidden>
        <div class="admin-toolbar">
          <div>
            <p class="eyebrow">Signed in</p>
            <h2 class="club-section-title">Admin dashboard</h2>
            <p class="admin-user-email" data-admin-email></p>
          </div>
          <button class="button button-secondary" type="button" data-admin-signout>Sign out</button>
        </div>

        <nav class="admin-page-tabs" aria-label="Admin sections">
          <a class="admin-page-tab is-active" href="/admin/" aria-current="page">Club data</a>
          <a class="admin-page-tab" href="/admin/jobs/">Stadium Jobs</a>
          <a class="admin-page-tab" href="/admin/news/">Latest News</a>
        </nav>

        <div class="admin-shell">
          <article class="card admin-card admin-create-card">
            <div class="admin-section-heading">
              <div>
                <p class="eyebrow">Club records</p>
                <h3>Manage club records</h3>
              </div>
              <span class="admin-status-pill">Supabase data</span>
            </div>

            <div class="admin-inline-tabs" role="tablist" aria-label="Club record actions">
              <button
                class="admin-inline-tab is-active"
                type="button"
                role="tab"
                aria-selected="true"
                data-club-draft-tab="add"
              >
                Add new
              </button>
              <button
                class="admin-inline-tab"
                type="button"
                role="tab"
                aria-selected="false"
                data-club-draft-tab="restore"
              >
                Restore
              </button>
            </div>

            <div class="admin-inline-panel" data-club-draft-panel="add">
              <p>
                Add the club name to create a new club record. We will try to pull the crest automatically,
                and you can finish the full club page content in the editor straight afterwards.
              </p>

              <form class="admin-create-form" data-club-create-form>
                <label>
                  Club name
                  <input
                    type="text"
                    name="clubName"
                    placeholder="Arsenal Football Club"
                    autocomplete="off"
                    required
                  />
                </label>
                <label>
                  Size
                  <select
                    name="clubSize"
                  >
                    <option value="">Select size</option>
                    <option value="Small">Small</option>
                    <option value="Medium">Medium</option>
                    <option value="Large">Large</option>
                  </select>
                </label>
                <button class="button button-primary" type="submit">Create club record</button>
              </form>

              <p class="admin-auth-status" data-club-create-status></p>
            </div>

            <div class="admin-inline-panel" data-club-draft-panel="restore" hidden>
              <p>
                Restore an archived club when it needs to come back into the live data workflow.
              </p>

              <div class="admin-archived-manager" data-admin-archived-manager hidden>
                <div class="admin-section-heading">
                  <div>
                    <p class="eyebrow">Archived clubs</p>
                    <h3>Restore an archived club</h3>
                  </div>
                  <span class="admin-status-pill is-archived">Hidden from live site</span>
                </div>

                <div class="admin-archived-actions">
                  <label>
                    Archived club
                    <select data-admin-archived-select>
                      <option value="">Select archived club</option>
                    </select>
                  </label>
                  <button class="button button-secondary" type="button" data-admin-restore-archived>Restore club</button>
                </div>
              </div>

              <div class="admin-list-state" data-admin-archived-empty hidden>
                <p>No archived clubs are available to restore right now.</p>
              </div>
            </div>
          </article>

          <section class="card admin-card">
            <div class="admin-section-heading">
              <div>
                <p class="eyebrow">Club data</p>
                <h3>All clubs</h3>
              </div>
              <a class="text-link" href="/venues/">View venue page</a>
            </div>

            <div class="admin-list-state" data-admin-clubs-loading>
              <p>Loading the club editor list.</p>
            </div>

            <div class="admin-list-state" data-admin-clubs-empty hidden>
              <p>No club records exist yet. Create your first club above.</p>
            </div>

            <div class="admin-list-state" data-admin-clubs-error hidden>
              <p>We could not load the club list right now.</p>
            </div>

            <div class="admin-club-filters" data-admin-club-filters hidden>
              <label>
                Status
                <select data-admin-status-filter>
                  <option value="">Published and draft clubs</option>
                  <option value="draft">Draft</option>
                  <option value="published">Published</option>
                  <option value="archived">Archived</option>
                </select>
              </label>
              <label>
                Size
                <select data-admin-size-filter>
                  <option value="">All sizes</option>
                  <option value="Small">Small</option>
                  <option value="Medium">Medium</option>
                  <option value="Large">Large</option>
                </select>
              </label>
            </div>

            <div class="admin-table-wrap" data-admin-clubs-list hidden>
              <table class="admin-club-table">
                <thead>
                  <tr>
                    <th>Club</th>
                    <th>Status</th>
                    <th>Size</th>
                    <th>Updated</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody data-admin-clubs-body></tbody>
              </table>
            </div>
          </section>
        </div>
      </div>
    </div>
  </section>

  <script>
    import { signOutAdminBrowserSession, verifyAdminBrowserSession } from "../../lib/admin-browser-auth";
    import { getBrowserSupabase } from "../../lib/supabase-browser";
    import { getClubSizeForClub, getStadiumExperienceClubs, saveClubSizeToDirectory } from "../../lib/stadiumexperience-clubs";

    const supabase = getBrowserSupabase();
    const gate = document.querySelector("[data-admin-gate]");
    const loading = document.querySelector("[data-admin-loading]");
    const denied = document.querySelector("[data-admin-denied]");
    const ready = document.querySelector("[data-admin-ready]");
    const emailElement = document.querySelector("[data-admin-email]");
    const signOutButton = document.querySelector("[data-admin-signout]");
    const createForm = document.querySelector("[data-club-create-form]");
    const createStatus = document.querySelector("[data-club-create-status]");
    const listLoading = document.querySelector("[data-admin-clubs-loading]");
    const listEmpty = document.querySelector("[data-admin-clubs-empty]");
    const listError = document.querySelector("[data-admin-clubs-error]");
    const clubFilters = document.querySelector("[data-admin-club-filters]");
    const statusFilter = document.querySelector("[data-admin-status-filter]");
    const sizeFilter = document.querySelector("[data-admin-size-filter]");
    const clubList = document.querySelector("[data-admin-clubs-list]");
    const clubTableBody = document.querySelector("[data-admin-clubs-body]");
    const clubDraftTabs = document.querySelectorAll("[data-club-draft-tab]");
    const clubDraftPanels = document.querySelectorAll("[data-club-draft-panel]");
    const archivedManager = document.querySelector("[data-admin-archived-manager]");
    const archivedEmpty = document.querySelector("[data-admin-archived-empty]");
    const archivedSelect = document.querySelector("[data-admin-archived-select]");
    const restoreArchivedButton = document.querySelector("[data-admin-restore-archived]");
    const sizeOptions = ["", "Small", "Medium", "Large"];
    let sizeRows = [];
    let allClubs = [];

    const getClubStatusValue = (club) => {
      if (club.archived) {
        return "archived";
      }

      return club.published ? "published" : "draft";
    };

    const getClubStatusLabel = (club) => {
      const statusValue = getClubStatusValue(club);

      if (statusValue === "archived") {
        return "Archived";
      }

      return statusValue === "draft" ? "Draft" : "Published";
    };

    const getClubStatusClass = (club) => {
      const statusValue = getClubStatusValue(club);
      if (statusValue === "archived") {
        return "is-archived";
      }

      return statusValue === "draft" ? "is-draft" : "is-published";
    };

    const setState = (state) => {
      loading.hidden = state !== "loading";
      denied.hidden = state !== "denied";
      ready.hidden = state !== "ready";
    };

    const setListState = (state) => {
      if (listLoading) listLoading.hidden = state !== "loading";
      if (listEmpty) listEmpty.hidden = state !== "empty";
      if (listError) listError.hidden = state !== "error";
      if (clubFilters) clubFilters.hidden = state !== "ready";
      if (clubList) clubList.hidden = state !== "ready";
    };

    const redirectToLogin = () => {
      window.location.href = "/admin/login/";
    };

    const renderArchivedManager = () => {
      if (!archivedManager || !archivedSelect) {
        return;
      }

      const archivedClubs = allClubs
        .filter((club) => club.archived)
        .sort((left, right) => left.club_name.localeCompare(right.club_name, "en", { sensitivity: "base" }));

      archivedManager.hidden = archivedClubs.length === 0;
      if (archivedEmpty) {
        archivedEmpty.hidden = archivedClubs.length !== 0;
      }

      const previousValue = archivedSelect.value;
      archivedSelect.innerHTML = '<option value="">Select archived club</option>';

      archivedClubs.forEach((club) => {
        const option = document.createElement("option");
        option.value = club.slug;
        option.textContent = club.club_name;
        archivedSelect.appendChild(option);
      });

      archivedSelect.value = archivedClubs.some((club) => club.slug === previousValue) ? previousValue : "";
    };

    const setClubDraftTab = (nextTab) => {
      clubDraftTabs.forEach((tab) => {
        const isActive = tab.getAttribute("data-club-draft-tab") === nextTab;
        tab.classList.toggle("is-active", isActive);
        tab.setAttribute("aria-selected", String(isActive));
      });

      clubDraftPanels.forEach((panel) => {
        panel.hidden = panel.getAttribute("data-club-draft-panel") !== nextTab;
      });
    };

    const buildCrest = (club) => {
      const crest = document.createElement("div");
      crest.className = "admin-club-crest admin-club-crest-small";

      if (club.crest_url) {
        const image = document.createElement("img");
        image.src = club.crest_url;
        image.alt = "";
        image.loading = "lazy";
        image.addEventListener("error", () => {
          image.remove();
          crest.textContent = club.club_name
            .split(/[\s&(]+/)
            .filter(Boolean)
            .slice(0, 2)
            .map((part) => part[0]?.toUpperCase() ?? "")
            .join("");
        });
        crest.appendChild(image);
      } else {
        crest.textContent = club.club_name
          .split(/[\s&(]+/)
          .filter(Boolean)
          .slice(0, 2)
          .map((part) => part[0]?.toUpperCase() ?? "")
          .join("");
      }

      return crest;
    };

    const createSizeEditor = (club, row) => {
      const wrap = document.createElement("div");
      wrap.className = "admin-size-editor";

      const select = document.createElement("select");
      select.className = "admin-size-select";
      select.setAttribute("aria-label", `Club size for ${club.club_name}`);

      sizeOptions.forEach((optionValue) => {
        const option = document.createElement("option");
        option.value = optionValue;
        option.textContent = optionValue || "Select size";
        option.selected = optionValue === (getClubSizeForClub(sizeRows, club) ?? "");
        select.appendChild(option);
      });

      const status = document.createElement("span");
      status.className = "admin-size-status";
      status.textContent = "";

      select.addEventListener("change", async () => {
        const previousValue = getClubSizeForClub(sizeRows, club) ?? "";

        if ((select.value ?? "") === previousValue) {
          status.textContent = "";
          return;
        }

        select.disabled = true;
        status.textContent = "Saving...";

        try {
          await saveClubSizeToDirectory(supabase, {
            slug: club.slug,
            clubName: club.club_name,
            size: select.value || null
          });

          const updatedCell = row.querySelector("[data-updated-cell]");
          if (updatedCell) {
            updatedCell.textContent = new Date().toLocaleString("en-GB");
          }

          sizeRows = await getStadiumExperienceClubs(supabase);
          status.textContent = "Saved";
          window.setTimeout(() => {
            if (status.textContent === "Saved") {
              status.textContent = "";
            }
          }, 1600);
        } catch (error) {
          select.value = previousValue;
          status.textContent = "";
          window.alert(error instanceof Error ? error.message : "Unable to save the club size.");
        } finally {
          select.disabled = false;
        }
      });

      wrap.append(select, status);
      return wrap;
    };

    const updateArchivedState = async (club, archived) => {
      const actionLabel = archived ? "archive" : "restore";
      const confirmationMessage = archived
        ? `Archive ${club.club_name}? You can restore it later from the archived filter.`
        : `Restore ${club.club_name} so you can edit it and make it live again?`;
      const confirmed = window.confirm(confirmationMessage);

      if (!confirmed) {
        return;
      }

      try {
        const updatePayload = {
          archived,
          published: archived ? false : club.published,
          updated_at: new Date().toISOString()
        };
        const { data, error } = await supabase
          .from("club_pages")
          .update(updatePayload)
          .eq("slug", club.slug)
          .select("slug, club_name, crest_url, published, archived, updated_at, draft_updated_at")
          .single();

        if (error) {
          throw new Error(error.message);
        }

        const updatedClub = data ?? { ...club, ...updatePayload, draft_updated_at: club.draft_updated_at ?? null };
        allClubs = allClubs.map((entry) => (entry.slug === club.slug ? { ...entry, ...updatedClub } : entry));
        renderArchivedManager();
        applyClubFilters();
      } catch (error) {
        window.alert(error instanceof Error ? error.message : `Unable to ${actionLabel} this club.`);
      }
    };

    const createClubRow = (club) => {
      const row = document.createElement("tr");
      row.className = "admin-club-table-row";

      const clubCell = document.createElement("td");
      const clubMeta = document.createElement("div");
      clubMeta.className = "admin-club-table-meta";

      const clubHeading = document.createElement("div");
      clubHeading.className = "admin-club-table-heading";
      const name = document.createElement("strong");
      name.textContent = club.club_name;
      clubHeading.append(name);
      clubMeta.append(buildCrest(club), clubHeading);
      clubCell.appendChild(clubMeta);

      const statusCell = document.createElement("td");
      const status = document.createElement("span");
      status.className = `admin-status-pill ${getClubStatusClass(club)}`;
      status.textContent = getClubStatusLabel(club);
      statusCell.appendChild(status);

      const sizeCell = document.createElement("td");
      sizeCell.appendChild(createSizeEditor(club, row));

      const updatedCell = document.createElement("td");
      updatedCell.setAttribute("data-updated-cell", "true");
      updatedCell.textContent = club.updated_at
        ? new Date(club.updated_at).toLocaleString("en-GB")
        : "Not yet updated";

      const actionsCell = document.createElement("td");
      const actions = document.createElement("div");
      actions.className = "admin-club-actions";
      actions.innerHTML = `
        <a class="button button-primary button-compact" href="/admin/clubs/${club.slug}/">Edit page</a>
        <button class="button ${club.archived ? "button-secondary" : "button-danger"} button-compact admin-archive-button" type="button">${club.archived ? "Restore" : "Archive"}</button>
      `;

      const archiveButton = actions.querySelector(".admin-archive-button");
      archiveButton?.addEventListener("click", async () => {
        await updateArchivedState(club, !club.archived);
      });

      actionsCell.appendChild(actions);
      row.append(clubCell, statusCell, sizeCell, updatedCell, actionsCell);
      return row;
    };

    const renderClubList = (clubs) => {
      if (!clubTableBody) {
        return;
      }

      if (!clubs.length) {
        clubTableBody.replaceChildren();
        setListState("empty");
        return;
      }

      const fragment = document.createDocumentFragment();
      clubs.forEach((club) => fragment.appendChild(createClubRow(club)));
      clubTableBody.replaceChildren(fragment);
      setListState("ready");
    };

    const applyClubFilters = () => {
      const selectedStatus = statusFilter?.value ?? "";
      const selectedSize = sizeFilter?.value ?? "";

      const filteredClubs = allClubs.filter((club) => {
        const clubStatus = getClubStatusValue(club);

        if (!selectedStatus && clubStatus === "archived") {
          return false;
        }

        if (selectedStatus && clubStatus !== selectedStatus) {
          return false;
        }

        if (selectedSize) {
          const clubSize = getClubSizeForClub(sizeRows, club) ?? "";
          if (clubSize !== selectedSize) {
            return false;
          }
        }

        return true;
      });

      renderClubList(filteredClubs);
    };

    const loadClubList = async () => {
      if (!clubList || !clubTableBody) {
        return;
      }

      setListState("loading");

      try {
        sizeRows = await getStadiumExperienceClubs(supabase);
        let clubs = [];

        const primaryQuery = await supabase
          .from("club_pages")
          .select("slug, club_name, crest_url, published, archived, updated_at, draft_updated_at")
          .order("club_name");

        if (primaryQuery.error) {
          const fallbackQuery = await supabase
            .from("club_pages")
            .select("slug, club_name, crest_url, published, updated_at")
            .order("club_name");

          if (fallbackQuery.error) {
            throw new Error(fallbackQuery.error.message);
          }

          clubs = Array.isArray(fallbackQuery.data)
            ? fallbackQuery.data.map((club) => ({ ...club, archived: false, draft_updated_at: null }))
            : [];
        } else {
          clubs = Array.isArray(primaryQuery.data) ? primaryQuery.data : [];
        }

        if (!clubs.length) {
          allClubs = [];
          clubTableBody.replaceChildren();
          renderArchivedManager();
          setListState("empty");
          return;
        }

        allClubs = clubs;
        renderArchivedManager();
        applyClubFilters();
      } catch (error) {
        console.error("Unable to load admin clubs", error);
        setListState("error");
      }
    };

    if (!supabase || !gate) {
      setState("denied");
    } else {
      verifyAdminBrowserSession(supabase).then((verifiedSession) => {
        if (!verifiedSession.ok) {
          setState("denied");
          redirectToLogin();
          return;
        }

        if (emailElement) {
          emailElement.textContent = verifiedSession.email ?? "";
        }

        setState("ready");
        loadClubList();
      });

      [statusFilter, sizeFilter].forEach((filter) => {
        filter?.addEventListener("change", () => {
          applyClubFilters();
        });
      });

      clubDraftTabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          const nextTab = tab.getAttribute("data-club-draft-tab");
          if (nextTab) {
            setClubDraftTab(nextTab);
          }
        });
      });

      restoreArchivedButton?.addEventListener("click", async () => {
        const selectedSlug = archivedSelect?.value ?? "";

        if (!selectedSlug) {
          window.alert("Please choose an archived club first.");
          return;
        }

        const club = allClubs.find((entry) => entry.slug === selectedSlug);

        if (!club) {
          window.alert("We could not find that archived club.");
          return;
        }

        await updateArchivedState(club, false);
      });

      createForm?.addEventListener("submit", async (event) => {
        event.preventDefault();

        const form = new FormData(createForm);
        const clubName = String(form.get("clubName") ?? "").trim();
        const clubSize = String(form.get("clubSize") ?? "").trim();

        if (!clubName) {
          if (createStatus) {
            createStatus.textContent = "Please enter the club name first.";
            createStatus.classList.add("is-error");
          }
          return;
        }

        if (createStatus) {
            createStatus.textContent = "Creating your new club record.";
          createStatus.classList.remove("is-error");
        }

        try {
          const slug = clubName
            .toLowerCase()
            .replace(/&/g, "and")
            .replace(/[^a-z0-9]+/g, "-")
            .replace(/^-+|-+$/g, "");

          const { data: existing, error: existingError } = await supabase
            .from("club_pages")
            .select("slug")
            .eq("slug", slug)
            .maybeSingle();

          if (existingError) {
            throw new Error(existingError.message);
          }

          if (existing?.slug) {
            throw new Error("A club with that name already exists.");
          }

          let crestUrl = null;

          try {
            const directoryResponse = await fetch("/api/club-directory", {
              headers: {
                accept: "application/json"
              }
            });

            if (directoryResponse.ok) {
              const directoryData = await directoryResponse.json();
              const clubs = Array.isArray(directoryData.clubs) ? directoryData.clubs : [];
              const matchingClub = clubs.find(
                (club) =>
                  typeof club?.name === "string" &&
                  club.name.localeCompare(clubName, "en", { sensitivity: "base" }) === 0
              );
              crestUrl = typeof matchingClub?.crest_url === "string" ? matchingClub.crest_url : null;
            }
          } catch (error) {
            console.error("Unable to load crest for new club", error);
          }

          const { data: draft, error } = await supabase
            .from("club_pages")
            .insert({
              slug,
              club_name: clubName,
              crest_url: crestUrl,
              introduction_heading: "Overview",
              introduction_paragraphs: [],
              social_links: [],
              spaces: [],
              events: [],
              key_facts: [],
              published: false,
              archived: false
            })
            .select("slug, club_name")
            .single();

          if (error || !draft) {
            throw new Error(error?.message ?? "Unable to create club");
          }

          if (clubSize) {
            await saveClubSizeToDirectory(supabase, {
              slug,
              clubName,
              size: clubSize
            });
          }

          if (createStatus) {
            createStatus.textContent = `Club record created for ${draft.club_name}. Opening the editor.`;
            createStatus.classList.remove("is-error");
          }

          window.location.href = `/admin/clubs/${draft.slug}/`;
        } catch (error) {
          if (createStatus) {
            createStatus.textContent = error instanceof Error ? error.message : "Unable to create the club record.";
            createStatus.classList.add("is-error");
          }
        }
      });

      signOutButton?.addEventListener("click", async () => {
        await signOutAdminBrowserSession(supabase);
        redirectToLogin();
      });
    }
  </script>
</BaseLayout>
