---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Admin" description="Stadium Experience admin area." chrome="admin">
  <section class="page-hero page-hero-tight">
    <p class="eyebrow">Admin</p>
    <h1>Website admin</h1>
    <p class="lede">
      A simple starting point for signed-in content editors. This can grow into a fuller website
      management area over time.
    </p>
  </section>

  <section class="section section-tight">
    <div class="admin-gate" data-admin-gate>
      <div class="directory-message-card" data-admin-loading>
        <p class="eyebrow">Checking access</p>
        <h3>Verifying your session.</h3>
        <p>Please wait while we confirm your admin login.</p>
      </div>

      <div class="directory-message-card" data-admin-denied hidden>
        <p class="eyebrow">Sign-in required</p>
        <h3>You need to sign in before accessing the admin area.</h3>
        <p><a class="text-link" href="/admin/login/">Go to admin login</a></p>
      </div>

      <div class="admin-dashboard" data-admin-ready hidden>
        <div class="admin-toolbar">
          <div>
            <p class="eyebrow">Signed in</p>
            <h2 class="club-section-title">Admin dashboard</h2>
            <p class="admin-user-email" data-admin-email></p>
          </div>
          <button class="button button-secondary" type="button" data-admin-signout>Sign out</button>
        </div>

        <div class="admin-shell">
          <article class="card admin-card admin-create-card">
            <div class="admin-section-heading">
              <div>
                <p class="eyebrow">Club drafts</p>
                <h3>Add a new club</h3>
              </div>
              <span class="admin-status-pill">Draft first</span>
            </div>

            <p>
              Add the club name to create a draft page. We will try to pull the crest automatically,
              keep the page unpublished while you edit it, and only show it publicly once you publish it.
            </p>

            <form class="admin-create-form" data-club-create-form>
              <label>
                Club name
                <input
                  type="text"
                  name="clubName"
                  placeholder="Arsenal Football Club"
                  autocomplete="off"
                  required
                />
              </label>
              <label>
                Size
                <select
                  name="clubSize"
                >
                  <option value="">Select size</option>
                  <option value="Small">Small</option>
                  <option value="Medium">Medium</option>
                  <option value="Large">Large</option>
                </select>
              </label>
              <button class="button button-primary" type="submit">Create draft club</button>
            </form>

            <p class="admin-auth-status" data-club-create-status></p>
          </article>

          <section class="card admin-card">
            <div class="admin-section-heading">
              <div>
                <p class="eyebrow">Club pages</p>
                <h3>All clubs</h3>
              </div>
              <a class="text-link" href="/venues/">View venue page</a>
            </div>

            <div class="admin-list-state" data-admin-clubs-loading>
              <p>Loading the club editor list.</p>
            </div>

            <div class="admin-list-state" data-admin-clubs-empty hidden>
              <p>No club drafts exist yet. Create your first club above.</p>
            </div>

            <div class="admin-list-state" data-admin-clubs-error hidden>
              <p>We could not load the club list right now.</p>
            </div>

            <div class="admin-table-wrap" data-admin-clubs-list hidden>
              <table class="admin-club-table">
                <thead>
                  <tr>
                    <th>Club</th>
                    <th>Status</th>
                    <th>Size</th>
                    <th>Updated</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody data-admin-clubs-body></tbody>
              </table>
            </div>
          </section>
        </div>
      </div>
    </div>
  </section>

  <script>
    import { getBrowserSupabase } from "../../lib/supabase-browser";
    import { getClubSizeForClub, getStadiumExperienceClubs, saveClubSizeToDirectory } from "../../lib/stadiumexperience-clubs";

    const supabase = getBrowserSupabase();
    const gate = document.querySelector("[data-admin-gate]");
    const loading = document.querySelector("[data-admin-loading]");
    const denied = document.querySelector("[data-admin-denied]");
    const ready = document.querySelector("[data-admin-ready]");
    const emailElement = document.querySelector("[data-admin-email]");
    const signOutButton = document.querySelector("[data-admin-signout]");
    const createForm = document.querySelector("[data-club-create-form]");
    const createStatus = document.querySelector("[data-club-create-status]");
    const listLoading = document.querySelector("[data-admin-clubs-loading]");
    const listEmpty = document.querySelector("[data-admin-clubs-empty]");
    const listError = document.querySelector("[data-admin-clubs-error]");
    const clubList = document.querySelector("[data-admin-clubs-list]");
    const clubTableBody = document.querySelector("[data-admin-clubs-body]");
    const sizeOptions = ["", "Small", "Medium", "Large"];
    let sizeRows = [];

    const setState = (state) => {
      loading.hidden = state !== "loading";
      denied.hidden = state !== "denied";
      ready.hidden = state !== "ready";
    };

    const setListState = (state) => {
      if (listLoading) listLoading.hidden = state !== "loading";
      if (listEmpty) listEmpty.hidden = state !== "empty";
      if (listError) listError.hidden = state !== "error";
      if (clubList) clubList.hidden = state !== "ready";
    };

    const redirectToLogin = () => {
      window.location.href = "/admin/login/";
    };

    const buildCrest = (club) => {
      const crest = document.createElement("div");
      crest.className = "admin-club-crest admin-club-crest-small";

      if (club.crest_url) {
        const image = document.createElement("img");
        image.src = club.crest_url;
        image.alt = "";
        image.loading = "lazy";
        image.addEventListener("error", () => {
          image.remove();
          crest.textContent = club.club_name
            .split(/[\s&(]+/)
            .filter(Boolean)
            .slice(0, 2)
            .map((part) => part[0]?.toUpperCase() ?? "")
            .join("");
        });
        crest.appendChild(image);
      } else {
        crest.textContent = club.club_name
          .split(/[\s&(]+/)
          .filter(Boolean)
          .slice(0, 2)
          .map((part) => part[0]?.toUpperCase() ?? "")
          .join("");
      }

      return crest;
    };

    const createSizeEditor = (club, row) => {
      const wrap = document.createElement("div");
      wrap.className = "admin-size-editor";

      const select = document.createElement("select");
      select.className = "admin-size-select";
      select.setAttribute("aria-label", `Club size for ${club.club_name}`);

      sizeOptions.forEach((optionValue) => {
        const option = document.createElement("option");
        option.value = optionValue;
        option.textContent = optionValue || "Select size";
        option.selected = optionValue === (getClubSizeForClub(sizeRows, club) ?? "");
        select.appendChild(option);
      });

      const status = document.createElement("span");
      status.className = "admin-size-status";
      status.textContent = "";

      select.addEventListener("change", async () => {
        const previousValue = getClubSizeForClub(sizeRows, club) ?? "";

        if ((select.value ?? "") === previousValue) {
          status.textContent = "";
          return;
        }

        select.disabled = true;
        status.textContent = "Saving...";

        try {
          await saveClubSizeToDirectory(supabase, {
            slug: club.slug,
            clubName: club.club_name,
            size: select.value || null
          });

          const updatedCell = row.querySelector("[data-updated-cell]");
          if (updatedCell) {
            updatedCell.textContent = new Date().toLocaleString("en-GB");
          }

          sizeRows = await getStadiumExperienceClubs(supabase);
          status.textContent = "Saved";
          window.setTimeout(() => {
            if (status.textContent === "Saved") {
              status.textContent = "";
            }
          }, 1600);
        } catch (error) {
          select.value = previousValue;
          status.textContent = "";
          window.alert(error instanceof Error ? error.message : "Unable to save the club size.");
        } finally {
          select.disabled = false;
        }
      });

      wrap.append(select, status);
      return wrap;
    };

    const createClubRow = (club) => {
      const row = document.createElement("tr");
      row.className = "admin-club-table-row";

      const clubCell = document.createElement("td");
      const clubMeta = document.createElement("div");
      clubMeta.className = "admin-club-table-meta";

      const clubHeading = document.createElement("div");
      clubHeading.className = "admin-club-table-heading";
      const name = document.createElement("strong");
      name.textContent = club.club_name;
      const venue = document.createElement("span");
      venue.textContent = club.venue_name ?? "Venue details still to be added";
      clubHeading.append(name, venue);
      clubMeta.append(buildCrest(club), clubHeading);
      clubCell.appendChild(clubMeta);

      const statusCell = document.createElement("td");
      const status = document.createElement("span");
      const hasDraftChanges = Boolean(club.draft_updated_at);
      status.className = `admin-status-pill ${club.published ? "is-published" : "is-draft"}`;
      status.textContent = club.published ? (hasDraftChanges ? "Published + draft" : "Published") : "Draft";
      statusCell.appendChild(status);

      const sizeCell = document.createElement("td");
      sizeCell.appendChild(createSizeEditor(club, row));

      const updatedCell = document.createElement("td");
      updatedCell.setAttribute("data-updated-cell", "true");
      updatedCell.textContent = club.updated_at
        ? new Date(club.updated_at).toLocaleString("en-GB")
        : "Not yet updated";

      const actionsCell = document.createElement("td");
      const actions = document.createElement("div");
      actions.className = "admin-club-actions";
      actions.innerHTML = `
        <a class="button button-primary button-compact" href="/admin/clubs/${club.slug}/">Edit page</a>
        <button class="button button-danger button-compact admin-delete-button" type="button">Delete</button>
      `;

      const deleteButton = actions.querySelector(".admin-delete-button");
      deleteButton?.addEventListener("click", async () => {
        const confirmed = window.confirm(`Delete ${club.club_name}? This cannot be undone.`);

        if (!confirmed) {
          return;
        }

        try {
          const { error } = await supabase.from("club_pages").delete().eq("slug", club.slug);

          if (error) {
            throw new Error(error.message);
          }

          row.remove();

          if (!clubTableBody?.children.length) {
            setListState("empty");
          }
        } catch (error) {
          window.alert(error instanceof Error ? error.message : "Unable to delete this club.");
        }
      });

      actionsCell.appendChild(actions);
      row.append(clubCell, statusCell, sizeCell, updatedCell, actionsCell);
      return row;
    };

    const loadClubList = async () => {
      if (!clubList || !clubTableBody) {
        return;
      }

      setListState("loading");

      try {
        sizeRows = await getStadiumExperienceClubs(supabase);
        let clubs = [];

        const primaryQuery = await supabase
          .from("club_pages")
          .select("slug, club_name, crest_url, venue_name, published, updated_at, draft_updated_at")
          .order("club_name");

        if (primaryQuery.error) {
          const fallbackQuery = await supabase
            .from("club_pages")
            .select("slug, club_name, crest_url, venue_name, published, updated_at")
            .order("club_name");

          if (fallbackQuery.error) {
            throw new Error(fallbackQuery.error.message);
          }

          clubs = Array.isArray(fallbackQuery.data)
            ? fallbackQuery.data.map((club) => ({ ...club, draft_updated_at: null }))
            : [];
        } else {
          clubs = Array.isArray(primaryQuery.data) ? primaryQuery.data : [];
        }

        if (!clubs.length) {
          clubTableBody.replaceChildren();
          setListState("empty");
          return;
        }

        const fragment = document.createDocumentFragment();
        clubs.forEach((club) => fragment.appendChild(createClubRow(club)));
        clubTableBody.replaceChildren(fragment);
        setListState("ready");
      } catch (error) {
        console.error("Unable to load admin clubs", error);
        setListState("error");
      }
    };

    if (!supabase || !gate) {
      setState("denied");
    } else {
      supabase.auth.getSession().then(({ data }) => {
        const session = data.session;

        if (!session) {
          setState("denied");
          return;
        }

        if (emailElement) {
          emailElement.textContent = session.user.email ?? "";
        }

        setState("ready");
        loadClubList();
      });

      createForm?.addEventListener("submit", async (event) => {
        event.preventDefault();

        const form = new FormData(createForm);
        const clubName = String(form.get("clubName") ?? "").trim();
        const clubSize = String(form.get("clubSize") ?? "").trim();

        if (!clubName) {
          if (createStatus) {
            createStatus.textContent = "Please enter the club name first.";
            createStatus.classList.add("is-error");
          }
          return;
        }

        if (createStatus) {
          createStatus.textContent = "Creating your new draft club page.";
          createStatus.classList.remove("is-error");
        }

        try {
          const slug = clubName
            .toLowerCase()
            .replace(/&/g, "and")
            .replace(/[^a-z0-9]+/g, "-")
            .replace(/^-+|-+$/g, "");

          const { data: existing, error: existingError } = await supabase
            .from("club_pages")
            .select("slug")
            .eq("slug", slug)
            .maybeSingle();

          if (existingError) {
            throw new Error(existingError.message);
          }

          if (existing?.slug) {
            throw new Error("A club with that name already exists.");
          }

          let crestUrl = null;

          try {
            const directoryResponse = await fetch("/api/club-directory", {
              headers: {
                accept: "application/json"
              }
            });

            if (directoryResponse.ok) {
              const directoryData = await directoryResponse.json();
              const clubs = Array.isArray(directoryData.clubs) ? directoryData.clubs : [];
              const matchingClub = clubs.find(
                (club) =>
                  typeof club?.name === "string" &&
                  club.name.localeCompare(clubName, "en", { sensitivity: "base" }) === 0
              );
              crestUrl = typeof matchingClub?.crest_url === "string" ? matchingClub.crest_url : null;
            }
          } catch (error) {
            console.error("Unable to load crest for new club", error);
          }

          const { data: draft, error } = await supabase
            .from("club_pages")
            .insert({
              slug,
              club_name: clubName,
              crest_url: crestUrl,
              introduction_heading: "Overview",
              introduction_paragraphs: [],
              social_links: [],
              spaces: [],
              events: [],
              key_facts: [],
              published: false
            })
            .select("slug, club_name")
            .single();

          if (error || !draft) {
            throw new Error(error?.message ?? "Unable to create club");
          }

          if (clubSize) {
            await saveClubSizeToDirectory(supabase, {
              slug,
              clubName,
              size: clubSize
            });
          }

          if (createStatus) {
            createStatus.textContent = `Draft created for ${draft.club_name}. Opening the editor.`;
            createStatus.classList.remove("is-error");
          }

          window.location.href = `/admin/clubs/${draft.slug}/`;
        } catch (error) {
          if (createStatus) {
            createStatus.textContent = error instanceof Error ? error.message : "Unable to create the club draft.";
            createStatus.classList.add("is-error");
          }
        }
      });

      signOutButton?.addEventListener("click", async () => {
        await supabase.auth.signOut();
        redirectToLogin();
      });
    }
  </script>
</BaseLayout>
