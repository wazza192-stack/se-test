---
import AwardsLandingPage from "../../components/awards/AwardsLandingPage.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAwardsLandingPage, getAwardsProgrammes } from "../../lib/awards-content";

const [page, programmes] = await Promise.all([getAwardsLandingPage(), getAwardsProgrammes()]);
---

<BaseLayout title="Awards" description={page.summary}>
  <AwardsLandingPage page={page} programmes={programmes} />
</BaseLayout>
