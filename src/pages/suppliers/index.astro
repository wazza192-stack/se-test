---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getSupplierFeatures, getSuppliersPageContent } from "../../lib/content";

const [pageContent, suppliers] = await Promise.all([getSuppliersPageContent(), getSupplierFeatures()]);
---

<BaseLayout
  seo={pageContent?.seo}
  title={pageContent?.seo?.metaTitle ?? "Suppliers"}
  description={pageContent?.seo?.metaDescription ?? "Supplier opportunities and partnership routes across the Stadium Experience network."}
  canonicalPath="/suppliers/"
  socialImage={null}
  noindex={pageContent?.seo?.noindex}
>
  <>
      <section class="page-hero">
        {pageContent?.hero.eyebrow && <p class="eyebrow">{pageContent.hero.eyebrow}</p>}
        <h1>{pageContent?.hero.title}</h1>
        {pageContent?.hero.intro && <p class="lede">{pageContent.hero.intro}</p>}
      </section>

      <section class="section section-tight">
        <div class="detail-grid venue-detail-grid">
          <article class="card info-card">
            <p class="eyebrow">Why partner</p>
            <h2>{pageContent?.benefitsHeading ?? "Useful routes into the network, not just a brochure page."}</h2>
            {pageContent?.benefits?.length ? (
              <ul class="feature-list">
                {pageContent.benefits.map((benefit) => (
                  <li>{benefit}</li>
                ))}
              </ul>
            ) : (
              <p>Supplier positioning points can be added here from the suppliers page singleton.</p>
            )}
          </article>

          {pageContent?.callout && (
            <article class="card info-card">
              {pageContent.callout.eyebrow && <p class="eyebrow">{pageContent.callout.eyebrow}</p>}
              <h2>{pageContent.callout.title}</h2>
              {pageContent.callout.body.length ? (
                pageContent.callout.body.map((paragraph) => <p>{paragraph}</p>)
              ) : (
                <p>Use this section to steer supplier enquiries toward the right contact path.</p>
              )}
              {pageContent.callout.cta && (
                <a class="button button-primary" href={pageContent.callout.cta.href}>
                  {pageContent.callout.cta.label}
                </a>
              )}
            </article>
          )}
        </div>
      </section>

      <section class="section section-tight">
        <div class="card-grid">
          {suppliers.length ? (
            suppliers.map((supplier) => (
              <article class="card">
                <p class="eyebrow">{supplier.category}</p>
                <h2>{supplier.name}</h2>
                <p>{supplier.summary}</p>
              </article>
            ))
          ) : (
            <article class="card info-card">
              <p class="eyebrow">Suppliers</p>
              <h2>Supplier opportunities will appear here soon.</h2>
              <p>
                Add supplier entries through the custom admin flow to populate this page while keeping
                the page-level marketing copy in the site content layer.
              </p>
            </article>
          )}
        </div>
      </section>
  </>
</BaseLayout>
